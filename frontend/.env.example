# ─────────────────────────────────────────────────────
# VaultLedger Frontend — Environment Variables
# Copy this file to .env and fill in your values
# In Vercel: add these in Project → Settings → Environment Variables
# ─────────────────────────────────────────────────────

# ── API URL ───────────────────────────────────────────
# Development: leave blank (Vite proxy handles /api → localhost:5000)
# Production: your Render backend URL (NO trailing slash)
VITE_API_URL=https://vault-ledger-api.onrender.com

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Same Client ID as backend — must match exactly
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
