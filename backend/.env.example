# ─────────────────────────────────────────────────────────────────────────────
# VaultLedger Backend — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Get from: https://mongodb.com/atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/vault_ledger?retryWrites=true&w=majority

# ── Authentication ────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_64_char_random_string
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your Vercel frontend URL (no trailing slash)
ALLOWED_ORIGINS=https://your-app.vercel.app

# ── Twilio WhatsApp OTP (phone login) ─────────────────────────────────────────
# Free sandbox — no credit card needed for testing
# Get from: https://console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
# Sandbox number — keep as-is for free sandbox
# Change to your Twilio number if you upgrade to paid
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── Email OTP / Forgot Password (Gmail) ───────────────────────────────────────
# Gmail App Password: myaccount.google.com/apppasswords (enable 2FA first)
SMTP_USER=youremail@gmail.com
SMTP_PASS=xxxx_xxxx_xxxx_xxxx
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Leave blank to disable Google login button
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ── Seed script (run once to create admin account) ────────────────────────────
# Usage: SEED_EMAIL=x SEED_PHONE=y SEED_PASSWORD=z SEED_NAME="Name" node utils/seed.js
SEED_EMAIL=admin@yourdomain.com
SEED_PHONE=9876543210
SEED_PASSWORD=ChangeMe@123
SEED_NAME=Admin
